{
  "name": "@citemind/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "setup:electron": "install-electron",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "build:mac": "pnpm build && node scripts/prepare-worker-runtime.mjs && electron-builder --mac --arm64",
    "verify:delivery": "node scripts/verify-mac-delivery.mjs",
    "preview": "electron-vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.citemind.desktop",
    "productName": "citeMind",
    "electronLanguages": [
      "en",
      "en_GB",
      "zh_CN",
      "zh_TW"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "staging/worker",
        "to": "worker"
      }
    ],
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
